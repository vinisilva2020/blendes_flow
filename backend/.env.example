# Copie este arquivo para .env e mantenha somente um bloco de ambiente ativo.
# O bloco local vem ativo. Variáveis do processo sobrescrevem este arquivo.

# ---------------------------------------------------------------------------
# Configuração compartilhada
# ---------------------------------------------------------------------------
DJANGO_SECRET_KEY_FILE=../infrastructure/secrets/django_secret_key.txt
JWT_SIGNING_KEY_FILE=../infrastructure/secrets/jwt_signing_key.txt

JWT_ACCESS_TOKEN_LIFETIME_SECONDS=300
AUTH_SESSION_LIFETIME_SECONDS=2592000
AUTH_LOGIN_THROTTLE_RATE=5/minute
AUTH_REFRESH_THROTTLE_RATE=30/minute
USERS_REGISTRATION_THROTTLE_RATE=5/hour

# ---------------------------------------------------------------------------
# Ambiente local - ativo por padrão
# ---------------------------------------------------------------------------
DJANGO_SETTINGS_MODULE=configuration.settings.local
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,[::1]
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DJANGO_CORS_ALLOW_CREDENTIALS=true

DATABASE_URL=sqlite:///db.sqlite3
DATABASE_CONN_MAX_AGE=0

# ---------------------------------------------------------------------------
# Ambiente beta - comente o bloco local e descomente este bloco
# ---------------------------------------------------------------------------
# DJANGO_SETTINGS_MODULE=configuration.settings.beta
# DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,nginx
# DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1
#
# DJANGO_STATIC_ROOT=/var/www/static
# DJANGO_MEDIA_ROOT=/var/www/media
#
# DJANGO_SECURE_SSL_REDIRECT=false
# DJANGO_SESSION_COOKIE_SECURE=false
# DJANGO_CSRF_COOKIE_SECURE=false
# DJANGO_SECURE_HSTS_SECONDS=0
#
# POSTGRES_DB=blendesflow
# POSTGRES_USER=blendesflow
# DB_NAME=blendesflow
# DB_USER=blendesflow
# DB_HOST=database
# DB_PORT=5432
# DATABASE_CONN_MAX_AGE=60

# ---------------------------------------------------------------------------
# Ambiente de produção - comente o bloco local e descomente este bloco
# ---------------------------------------------------------------------------
# DJANGO_SETTINGS_MODULE=configuration.settings.prod
# DJANGO_ALLOWED_HOSTS=example.com,www.example.com
# DJANGO_CSRF_TRUSTED_ORIGINS=http://example.com,http://www.example.com
#
# DJANGO_STATIC_ROOT=/var/www/static
# DJANGO_MEDIA_ROOT=/var/www/media
#
# Altere estes valores para true/31536000 depois de habilitar HTTPS no Nginx.
# DJANGO_SECURE_SSL_REDIRECT=false
# DJANGO_SESSION_COOKIE_SECURE=false
# DJANGO_CSRF_COOKIE_SECURE=false
# DJANGO_SECURE_HSTS_SECONDS=0
#
# POSTGRES_DB=blendesflow
# POSTGRES_USER=blendesflow
# DB_NAME=blendesflow
# DB_USER=blendesflow
# DB_HOST=database
# DB_PORT=5432
# DATABASE_CONN_MAX_AGE=60
